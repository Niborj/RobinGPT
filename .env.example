# Optional: Set your OpenAI API key here as a server-side fallback.
# If not set, users can supply their own key directly in the browser UI
# via Settings → LLM tab → "OpenAI API Key".
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Set to "true" to allow connecting to local/custom LLM servers (e.g., Ollama, LM Studio)
# ALLOW_LOCAL_LLM=true
